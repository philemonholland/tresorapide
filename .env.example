# Copy this file to .env before the first Docker Compose deployment.
# Replace 192.168.1.50 with the host's LAN IP address or local DNS name.
# Leave .env absent if you want Django to fall back to SQLite for quick local validation.
DJANGO_SECRET_KEY=change-me-for-local-network-deployment
DJANGO_DEBUG=False
# CRITICAL: Replace 192.168.1.50 below with the actual LAN IP or hostname of this server.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,192.168.1.50
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.50:8000
DJANGO_TIME_ZONE=America/Toronto
DJANGO_SERVE_MEDIA=True
DJANGO_SERVE_STATIC=True
DJANGO_STATIC_ROOT=/data/static
DJANGO_MEDIA_ROOT=/data/media
APP_PUBLISHED_PORT=8000
POSTGRES_PUBLISHED_PORT=127.0.0.1:5432

DATABASE_ENGINE=django.db.backends.postgresql
POSTGRES_DB=tresorapide
POSTGRES_USER=tresorapide
POSTGRES_PASSWORD=change-me-too
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=5
DB_WAIT_TIMEOUT=60
